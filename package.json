{
	"name": "sorttool-server",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"bin": "dist-server/bundle.js",
	"scripts": {
		"start-server": "npm run build && nodemon",
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"preview": "vite preview",
		"test:unit": "vitest",
		"build-only": "vite build",
		"type-check": "vue-tsc --build",
		"lint": "run-s lint:*",
		"lint:oxlint": "oxlint . --fix",
		"lint:eslint": "eslint . --fix --cache",
		"format": "prettier --write --experimental-cli src/",
		"build:frontend": "npm run build",
		"copy:dist": "shx rm -rf ./dist_bundled && shx cp -r ./dist ./dist_bundled",
		"build:server": "npx esbuild backend/server/server.ts --bundle --platform=node --format=esm --outfile=dist-server/bundle.js --external:pkg-fetch --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
		"build:exe": "npm run build:server && npm run build:frontend && npm run copy:dist && npm run bundle",
		"build:server-v12": "npx esbuild backend/server/server.ts --bundle --platform=node --format=cjs --target=node12 --outfile=dist-server/bundle.js --external:pkg-fetch",
		"bundle": "npx @yao-pkg/pkg . --targets node20-win-x64 --output ./release/sorttool.exe --public --esm",
		"bundle:12": "npx pkg@5.8.1 . --targets node12-win-x64 --output ./release/sorttoolW7.exe --public",
		"build:exe-v12": "npm run build:server-v12 && npm run build:frontend && npm run copy:dist && npm run bundle:12"
	},
	"pkg": {
		"scripts": [
			"dist-server/bundle.js"
		],
		"assets": [
			"dist_bundled/**/*"
		]
	},
	"dependencies": {
		"chokidar": "^3.6.0",
		"cors": "^2.8.5",
		"dotenv": "^10.0.0",
		"express": "^4.19.2",
		"pinia": "^3.0.4",
		"socket.io": "^4.8.3",
		"socket.io-client": "^4.8.3",
		"vue": "^3.5.27",
		"vue-router": "^5.0.1",
		"vue3-select-component": "^0.16.0",
		"vuetify": "^3.12.0"
	},
	"devDependencies": {
		"@mdi/font": "^7.4.47",
		"@tsconfig/node24": "^24.0.4",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsdom": "^27.0.0",
		"@types/node": "^24.10.13",
		"@vitejs/plugin-vue": "^6.0.3",
		"@vitest/eslint-plugin": "^1.6.6",
		"@vue/eslint-config-typescript": "^14.6.0",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.8.1",
		"@yao-pkg/pkg": "^6.14.1",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-oxlint": "~1.42.0",
		"eslint-plugin-vue": "~10.7.0",
		"jiti": "^2.6.1",
		"jsdom": "^27.4.0",
		"nodemon": "^3.1.14",
		"npm-run-all2": "^8.0.4",
		"oxlint": "~1.42.0",
		"prettier": "3.8.1",
		"shx": "^0.4.0",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-vue-devtools": "^8.0.5",
		"vitest": "^4.0.18",
		"vue-tsc": "^3.2.4"
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	}
}
